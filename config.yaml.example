# AiCSO 配置文件
# 复制为 config.yaml 并填入实际值

llm:
  enabled: true          # false = 关闭所有LLM调用，纯聚合模式运行（内网无LLM时使用）
  default_provider: deepseek
  providers:
    deepseek:
      api_key: your-api-key-here
      base_url: https://api.deepseek.com
      model: deepseek-chat
      max_tokens: 4096
      temperature: 0.1
    openai:
      api_key: ${OPENAI_API_KEY}
      model: gpt-4o
      max_tokens: 4096
      temperature: 0.1
    ollama:
      base_url: http://localhost:11434
      model: qwen2.5:14b
      max_tokens: 4096

  budget:
    daily_limit: 1000000
    monthly_limit: 20000000
    alert_on_percent: 80

  context:
    max_context_tokens: 120000
    summary_threshold: 80000
    truncation_strategy: smart

database:
  url: sqlite+aiosqlite:///./aicso.db

vector_store:
  provider: chromadb
  path: ./data/chromadb
  embedding_model: BAAI/bge-small-zh-v1.5
  similarity_threshold: 0.7

server:
  host: 0.0.0.0
  port: 8000

logging:
  level: INFO
  format: json

# 数据源配置
